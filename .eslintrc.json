{
  "env": {
    "browser": true,
    "es2021": true,
    "node": true
  },
  "extends": [
    "eslint:recommended",
    "plugin:vue/vue3-recommended"
  ],
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "plugins": [
    "vue"
  ],
  "rules": {
    // 生产环境禁止使用 console.log
    "no-console": "warn",
    
    // Vue 相关规则
    "vue/multi-word-component-names": "off",
    "vue/no-unused-vars": "error",
    
    // 代码质量规则
    "no-unused-vars": "warn",
    "no-debugger": "warn"
  },
  "globals": {
    "defineProps": "readonly",
    "defineEmits": "readonly",
    "defineExpose": "readonly",
    "withDefaults": "readonly"
  }
}
